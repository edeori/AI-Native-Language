{
  "name": "ai-native-language",
  "private": true,
  "type": "module",
  "workspaces": [
    "mcp-servers/*",
    "vscode-extension"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "build:vscode-extension": "npm -w vscode-extension run build",
    "dev:semantic-core": "tsx mcp-servers/semantic-core/src/index.ts",
    "dev:validator": "tsx mcp-servers/validator/src/index.ts",
    "dev:compiler": "tsx mcp-servers/compiler/src/index.ts",
    "dev:http:semantic-core": "MCP_TRANSPORT_MODE=http PORT=3001 tsx mcp-servers/semantic-core/src/index.ts",
    "dev:http:validator": "MCP_TRANSPORT_MODE=http PORT=3002 tsx mcp-servers/validator/src/index.ts",
    "dev:http:compiler": "MCP_TRANSPORT_MODE=http PORT=3003 tsx mcp-servers/compiler/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
